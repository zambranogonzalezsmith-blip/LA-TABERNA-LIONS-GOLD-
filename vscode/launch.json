{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🦁 LIONS-GOLD Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "env": {
                "PORT": "8080"
            }
        },
        {
            "name": "🌐 Open in Browser",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}
